{
  "name": "founder-bot",
  "version": "1.0.0",
  "description": "Telegram group bot for founders — memory, decisions, action items, daily briefings",
  "main": "dist/bot.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/bot.js",
    "dev": "ts-node-dev --respawn src/bot.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@octokit/rest": "^21.0.0",
    "@supabase/supabase-js": "^2.47.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "grammy": "^1.31.0",
    "node-cron": "^3.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  }
