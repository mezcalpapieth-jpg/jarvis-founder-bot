# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# GitHub (optional — omit both to disable GitHub features)
# Fine-grained PAT with: Contents: read, Pull requests: read, Issues: read
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Comma-separated repos to watch
GITHUB_REPOS=your-org/backend,your-org/frontend

# Webhook (Railway provides this automatically)
WEBHOOK_DOMAIN=https://your-app.up.railway.app
PORT=3000

# Timezone for the 08:00 cron job
TZ=America/New_York

# Bot config
FOUNDER_CHAT_ID=your_group_chat_id
